    <motor name="mouse_joint_1" joint="mouse_joint_1" ctrllimited="true" ctrlrange="-1 1" gear="1" />
    <motor name="mouse_joint_2" joint="mouse_joint_2" ctrllimited="true" ctrlrange="-1 1" gear="1" /> -->
