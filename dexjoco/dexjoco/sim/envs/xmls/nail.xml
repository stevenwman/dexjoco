<mujoco model="nail">
  <asset>
    <texture name="steel_texture" type="2d" file="./table_arena/textures/metal.png"/>
    <material name="steel_mat" texture="steel_texture" texrepeat="1 1" texuniform="true" specular="0.8" shininess="0.5" rgba="1 1 1 1"/>
    <material name="steel_head_mat" texture="steel_texture" texrepeat="1 1" texuniform="true" specular="0.6" shininess="0.4" rgba="1 1 1 1"/>
  </asset>

  <worldbody>
    <!-- Nail body with kinematic (mocap) positioning. -->
    <body name="nail" pos="-0.05 0.05 1.08" mocap="true">

      <geom name="nail_head" type="cylinder" pos="0 0 0.0036" quat="1 0 0 0"
            size="0.0182 0.0048" material="steel_head_mat" density="7850"
            friction="1.0 0.1 0.01" solref="0.005 1.0" solimp="0.95 0.99 0.001" condim="3"
            />

      <geom name="nail_shaft" type="cylinder" pos="0 0 -0.0363" quat="1 0 0 0"
            size="0.0073 0.0363" material="steel_mat" density="7850"
            friction="2.0 0.5 0.1" solref="0.005 1.0" solimp="0.95 0.99 0.001" condim="3"
            />

      <site name="nail_top_site" pos="0 0 0.0073" rgba="1 0 0 0" size="0.005"/>
      <site name="nail_bottom_site" pos="0 0 -0.0363" rgba="0 1 0 0" size="0.005"/>
      <site name="nail_center_site" pos="0 0 0" rgba="0 0 1 0" size="0.005"/>
    </body>
  </worldbody>

</mujoco>
