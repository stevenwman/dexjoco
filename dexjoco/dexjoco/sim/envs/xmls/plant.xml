<mujoco model="model">
  <compiler angle="radian"/>

  <asset>
    <texture file="plant/visuals/material_0.png" name="tex-model" type="2d"/>
    <texture type="2d" name="image0" file="plant/visuals/image0.png"/>
    <texture type="2d" name="image1" file="plant/visuals/image1.png"/>
    <texture type="2d" name="image2" file="plant/visuals/image2.png"/>
    <texture type="2d" name="image3" file="plant/visuals/image3.png"/>

    <material name="model" reflectance="0.5" texrepeat="1 1" texture="tex-model" texuniform="false"/>
    <material name="blinn1SG" texture="image0" specular="0.5" shininess="0.15999998099999999"/>
    <material name="blinn2SG" texture="image1" specular="0.5" shininess="0.15999998099999999"/>
    <material name="blinn3SG" texture="image2" specular="0.5" shininess="0.15999998099999999"/>
    <material name="blinn4SG" texture="image3" specular="0.5" shininess="0.0"/>

    <!-- meshes scaled to 0.3 -->
    <mesh file="plant/visuals/model_0.obj" name="model_0_vis" scale="0.3 0.3 0.3"/>
    <mesh file="plant/visuals/model_1.obj" name="model_1_vis" scale="0.3 0.3 0.3"/>
    <mesh file="plant/visuals/model_2.obj" name="model_2_vis" scale="0.3 0.3 0.3"/>
    <mesh file="plant/visuals/model_3.obj" name="model_3_vis" scale="0.3 0.3 0.3"/>
  </asset>

  <default>
    <default class="plant_visual">
      <geom conaffinity="0" contype="0" group="1" type="mesh"/>
    </default>
    <default class="plant_collision">
      <geom group="3" rgba="0.5 0 0 0.5"/>
    </default>
  </default>

  <worldbody>
    <!-- object body -->
    <body name="plant" pos="0 0 1.06">
      <geom solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="mesh" mesh="model_0_vis" material="blinn2SG" class="plant_visual"/>
      <geom solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="mesh" mesh="model_1_vis" material="blinn1SG" class="plant_visual"/>
      <geom solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="mesh" mesh="model_2_vis" material="blinn4SG" class="plant_visual"/>
      <geom solimp="0.998 0.998 0.001" solref="0.001 1" density="100" friction="0.95 0.3 0.1" type="mesh" mesh="model_3_vis" material="blinn3SG" class="plant_visual"/>
      <geom class="plant_collision" type="cylinder" pos="0 0 0" size="0.1 0.15"/>
      <geom class="plant_visual" type="cylinder" pos="0 0 0" size="0.2 0.2" rgba="0 0.5 0 0.5" group="5"/>
      <site name="ext_p0" rgba="0 0 0 0" size="0.003" pos="-0.105 -0.105 -0.15"/>
      <site name="ext_px" rgba="1 0 0 0" size="0.003" pos="0.105 -0.105 -0.15"/>
      <site name="ext_py" rgba="0 1 0 0" size="0.003" pos="-0.105 0.105 -0.15"/>
      <site name="ext_pz" rgba="0 0 1 0" size="0.003" pos="-0.105 -0.105 0.15"/>
    </body>
  </worldbody>
</mujoco>
