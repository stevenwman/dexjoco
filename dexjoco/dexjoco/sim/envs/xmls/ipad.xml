    <mesh name="ipad_mesh" file="ipad/ipad_thin_2.obj" scale="0.4 0.4 0.4"/>
  </asset>

  <worldbody>
    <body name="ipad_body" pos="-0.17 0.2 1.06" quat="0 -0.5 0 0.8660254">
      <freejoint name="ipad_freejoint"/>
      <geom material="Material_grey" mesh="ipad_mesh" class="ipad_visual"/>
      <!-- <geom class="ipad_collision" size="0.134766 0.207413 0.018" pos="0.000212 0.207413 -0.001296" mass="0.01" /> -->
      <geom name="ipad_collision_ll" class="ipad_collision" size="0.067383 0.1037065 0.014285" pos="-0.067171 0.1037065 -0.001296" mass="0.1" friction="1 0.005 0.0001" rgba="0.8 0.8 0.8 0.9"/>
