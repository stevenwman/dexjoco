    <material name="mat_digit_0" texture="digit_0_tex" specular="0.1" shininess="0.1" texuniform="false" texrepeat="1 1"/>
    <material name="mat_digit_1" texture="digit_1_tex" specular="0.1" shininess="0.1" texuniform="false" texrepeat="1 1"/>
