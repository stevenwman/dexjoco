<mujoco model="ipad_with_keypad">
  <default>
    <default class="ipad_visual">
      <geom group="2" type="mesh" contype="0" conaffinity="0" density="0"/>
    </default>
    <default class="ipad_collision">
      <geom group="3" type="box"/>
