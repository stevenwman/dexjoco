<?xml version='1.0' encoding='utf-8'?>
<mujoco model="microwave2_scaled_0.6">
  <asset>
    <texture file="robocasa_microwave/visuals/material_0.png" name="tex-microwave2" type="2d"/>
    <texture type="2d" name="microwave_image" file="robocasa_microwave/visuals/image0.png"/>
    <material name="microwave2" reflectance="0.5" texrepeat="1 1" texture="tex-microwave2" texuniform="false"/>
    <material name="Oven" texture="microwave_image" specular="0.5" shininess="0.25"/>
    <!-- 将 visual mesh 缩放为 0.6 (原 0.5 -> 0.6) -->
    <mesh file="robocasa_microwave/visuals/microwave2_0.obj" name="microwave2_0_vis" scale="0.6 0.6 0.6"/>
    <mesh file="robocasa_microwave/visuals/microwave2_door_1.obj" name="microwave2_door_0_vis" scale="0.6 0.6 0.6"/>
  </asset>

  <default>
    <default class="microwave_visual">
      <geom conaffinity="0" contype="0" group="1" type="mesh"/>
    </default>
    <default class="microwave_collision">
      <geom group="3" rgba="0.5 0 0 0.5"/>
    </default>
  </default>

  <worldbody>
    <body>
      <body name="microwave_object" pos="-0.05 0.12 1.1" quat="0.70710678 0 0 -0.70710678">
        <!-- visual mesh (mesh 自带 scale=0.6) -->
        <geom solimp="0.998 0.998 0.001"
              solref="0.001 1"
              density="100"
              friction="0.95 0.3 0.1"
              type="mesh"
              mesh="microwave2_0_vis"
              material="Oven"
              class="microwave_visual"/>

        <!-- Back Wall (pos & size 均放大 1.2x) -->
        <geom class="microwave_collision" type="box" pos="0 0.2475 0" size="0.3 0.0192 0.18"/>

        <!-- Floor -->
        <geom class="microwave_collision" type="box" pos="0 0.045 -0.153" size="0.3 0.2112 0.027"/>

        <!-- Top -->
        <geom class="microwave_collision" type="box" pos="0 0.045 0.165" size="0.3 0.2112 0.021"/>

        <!-- Left Wall-->
        <geom class="microwave_collision" type="box" pos="-0.282 0.045 0" size="0.024 0.2112 0.18"/>

        <!-- Right Wall-->
        <geom class="microwave_collision" type="box" pos="0.228 0.045 0" size="0.072 0.2112 0.18"/>

        <!-- Keypad -->
        <geom class="microwave_collision" type="box" pos="0.243 -0.195 0.009" size="0.057 0.0303 0.174"/>

        <!-- start/stop buttons -->
        <geom class="microwave_collision" type="box" pos="0.267 -0.195 -0.072" size="0.025 0.0306 0.025" name="start_button" rgba="0.0 0.5 0 0.5"/>
        <geom class="microwave_collision" type="box" pos="0.219 -0.195 -0.072" size="0.018 0.0306 0.015" name="stop_button" rgba="0.0 0.5 0 0.5"/>

        <!-- tray (cylinder: radius, half-height) -->
        <geom class="microwave_collision" type="cylinder" pos="-0.054 0.03 -0.126" size="0.15 0.003" rgba="0 1 1 1" name="tray"/>

        <body name="door">
          <!-- joint anchor 同样放大 -->
          <joint axis="0 0 1"
                 limited="true"
                 name="microjoint"
                 range="-1.6 0"
                 damping="2"
                 frictionloss="2"
                 armature=".01"
                 pos="-0.27 -0.2202 0"
                 ref="0"/>

          <!-- door visual (mesh，mesh scale 已设 0.6) -->
          <geom solimp="0.998 0.998 0.001"
                solref="0.001 1"
                density="100"
                friction="0.95 0.3 0.1"
                type="mesh"
                mesh="microwave2_door_0_vis"
                material="Oven"
                class="microwave_visual"/>

          <!-- Door collision -->
          <geom class="microwave_collision" type="box" pos="-0.045 -0.1962 0.006" size="0.228 0.024 0.168"/>

          <!-- Handle Top -->
          <geom class="microwave_collision" type="box" pos="0.162 -0.243 0.108" size="0.018 0.0228 0.0126"/>

          <!-- Handle Bottom -->
          <geom class="microwave_collision" type="box" pos="0.162 -0.243 -0.09" size="0.018 0.0228 0.0126"/>

          <!-- Handle Main -->
          <geom class="microwave_collision" type="box" pos="0.162 -0.275 0.0108" size="0.018 0.0096 0.108" name="door_handle"/>

          <!-- door sites (pos 缩放) -->
          <site rgba="1 0 0 0" size="0.006" pos="-0.045 -0.222 0.006" name="door_p1"/>
          <site rgba="0 1 0 0" size="0.006" pos="-0.015 -0.222 0.006" name="door_p2"/>
          <site rgba="0 0 1 0" size="0.006" pos="-0.045 -0.222 0.036" name="door_p3"/>
        </body>

        <!-- exterior bounding box points (缩放后) -->
        <site rgba="1 1 1 0" size="0.012" pos="-0.306 -0.222 -0.1698" name="ext_p0"/>
        <site rgba="1 0 0 0" size="0.012" pos="0.306 -0.222 -0.1698" name="ext_px"/>
        <site rgba="0 1 0 0" size="0.012" pos="-0.306 0.273 -0.1698" name="ext_py"/>
        <site rgba="0 0 1 0" size="0.012" pos="-0.306 -0.222 0.183" name="ext_pz"/>

        <!-- interior bounding box points (缩放后) -->
        <site rgba="0.5 0.5 0.5 0" size="0.012" pos="-0.258 -0.162 -0.12" name="int_p0"/>
        <site rgba="1 1 0 0" size="0.012" pos="0.156 -0.162 -0.12" name="int_px"/>
        <site rgba="0 1 1 0" size="0.012" pos="-0.258 0.222 -0.12" name="int_py"/>
        <site rgba="1 0 1 0" size="0.012" pos="-0.258 -0.162 0.144" name="int_pz"/>
      </body>
    </body>
  </worldbody>
</mujoco>
